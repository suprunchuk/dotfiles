[user]
	name = Pasha Suprunchuk
	email = 
[commit]
	gpgsign = true
	
[alias]
    # List current aliases
    ala = "!git config --get-regexp '^alias\\.' | sed -e 's/^alias\\.//' -e 's/ / = /'"
    # Show full log graph for all branches (compact)
    l = log --graph --decorate --oneline --all
    # Show a nicer, information-dense log (hash, date, author, refs, subject)
    lg = log --graph --all --decorate --date=short --pretty=format:'%C(yellow)%h%Creset %Cgreen%ad%Creset %C(cyan)%an%Creset %C(auto)%d%Creset %s'
    # View the current working tree status using the short format
    s = status --short --branch
    # Show the diff between the latest commit and the current state
    d = !"git diff-index --quiet HEAD -- || clear; git --no-pager diff --patch-with-stat"
    # Pull in remote changes for the current repository and all its submodules
    p = !"git pull; git submodule foreach git pull origin main"
    # Clone a repository including all submodules
    c = clone --recursive
    # Commit all changes
    ca = !git add -A && git commit -av
    # Commit only staged changes (do not auto-add)
    cs = commit -v
    # Switch to a branch, but don't create it
    co = checkout
    # Switch to a branch, creating it if necessary
    go = checkout -B
    # Show verbose output about tags, branches or remotes
    tags = tag -l
    branches = branch -a
    remotes = remote -v
    # Credit an author on the latest commit
    credit = "!f() { git commit --amend --author \"$1 <$2>\" -C HEAD; }; f"
    # Interactive rebase with the given number of latest commits
    reb = "!r() { git rebase -i HEAD~$1; }; r"
    # Remove branches that have already been merged with master
    dm = "!git branch --merged | grep -v '\\*' | xargs -n 1 git branch -d"
    # Undo last commit but keep changed files in stage
    uncommit = reset --soft HEAD~1
    # Undo last commit but keep changes unstaged (mixed reset)
    undo = reset --mixed HEAD~1
    # Fetch all remotes and remove stale references
    fa = fetch --all --prune
    # Quick save work-in-progress (WIP) commit (message optional)
    wip = "!f(){ msg=${1:-WIP}; git add -A && git commit -m \"$msg\"; }; f"
    # Force push safely (uses lease)
    pf = push --force-with-lease

[apply]
    # Detect whitespace errors when applying a patch
    whitespace = warn

[core]
    # Use custom `.gitignore` and `.gitattributes`
    excludesfile = ~/.gitignore
    attributesfile = ~/.gitattributes
    # Treat spaces before tabs, lines that are indented with 8 or more spaces, and
    # all kinds of trailing whitespace as an error.
    # [default] trailing-space: looks for spaces at the end of a line
    # [default] space-before-tab: looks for spaces before tabs at the beginning of
    # a line
    whitespace = space-before-tab,tab-in-indent,trailing-space,tabwidth=4

    # Speed up commands involving untracked files such as `git status`.
    # https://git-scm.com/docs/git-update-index#_untracked_cache
    untrackedCache = true
    editor = nano
    
[color]
    # Use colors in Git commands that are capable of colored output when
    # outputting to the terminal. (This is the default setting in Git ≥ 1.8.4.)
    ui = auto
[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green
[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold
[color "status"]
    added = yellow
    changed = green
    untracked = cyan
    branch = magenta
[merge]
    # Include summaries of merged commits in newly created merge commit messages
    log = true

# URL shorthands
[url "git@github.com:"]
    insteadOf = "gh:"
    pushInsteadOf = "github:"
    pushInsteadOf = "git://github.com/"
[url "git://github.com/"]
    insteadOf = "github:"
[url "git@gist.github.com:"]
    insteadOf = "gst:"
    pushInsteadOf = "gist:"
    pushInsteadOf = "git://gist.github.com/"
[url "git://gist.github.com/"]
    insteadOf = "gist:"

[push]
    default = simple
    autoSetupRemote = true

[credential]
    helper = manager
[gui]
	encoding = utf-8
	fontui = -family Roboto -size 9 -weight normal -slant roman -underline 0 -overstrike 0
	fontdiff = -family \"JetBrains Mono\" -size 10 -weight normal -slant roman -underline 0 -overstrike 0